% =================================================================
% beamerfontthemeMyEspresso.sty
% Font configuration for the MyEspresso Beamer theme.
% =================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerfontthemeMyEspresso}%
  [2026/04/11 v2.0 MyEspresso Font Theme for Beamer]

\mode<presentation>

\usefonttheme{professionalfonts}

% Element fonts
\setbeamerfont{block title}{size=\bfseries}
\setbeamerfont{author}{size=\bfseries\large}
\setbeamerfont{institute}{size=\normalsize\itshape}
\setbeamerfont{title}{size=\huge\bfseries}
\setbeamerfont{date}{size=\footnotesize}
\setbeamerfont{subtitle}{size=\Large\normalfont\slshape}
\setbeamerfont{mail}{size=\small\ttfamily}
\setbeamerfont{frametitle}{size=\bfseries\Large}

% Sidebar fonts (conditional)
\ifbeamer@me@sidebar
  \setbeamerfont{section in sidebar}{size=\fontsize{5}{6}\selectfont}
  \setbeamerfont{subsection in sidebar}{size=\fontsize{4}{5}\selectfont}
  \setbeamerfont{title in sidebar}{size=\scriptsize}
  \setbeamerfont{author in sidebar}{size=\tiny}
\fi

\mode<all>
\endinput
