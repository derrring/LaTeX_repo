% =================================================================
% beamerthemeMyEspresso.sty
% Main theme file for MyEspresso Beamer theme.
% Based on the Amurmaple theme by Maxime CHUPIN.
% =================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeMyEspresso}[2026/04/11 v2.0 MyEspresso Beamer Theme]

\mode<presentation>

\RequirePackage{e_core}
\setbeamercovered{dynamic}

% =================================================================
% Theme options
% =================================================================

% -- Display toggles (positive naming: true = feature shown) --
\newif\ifbeamer@me@showgauge
\beamer@me@showgaugetrue
\DeclareOptionBeamer{nogauge}{\beamer@me@showgaugefalse}

\newif\ifbeamer@me@showmail
\beamer@me@showmailtrue
\DeclareOptionBeamer{nomail}{\beamer@me@showmailfalse}

% -- Visual options --
\newif\ifbeamer@me@delaunay
\beamer@me@delaunayfalse
\DeclareOptionBeamer{delaunay}{\beamer@me@delaunaytrue}

\newif\ifbeamer@me@myespressoblue
\beamer@me@myespressobluefalse
\DeclareOptionBeamer{myespressoblue}{\beamer@me@myespressobluetrue}

\newif\ifbeamer@me@myespressogreen
\beamer@me@myespressogreenfalse
\DeclareOptionBeamer{myespressogreen}{\beamer@me@myespressogreentrue}

\newif\ifbeamer@me@myespressoblack
\beamer@me@myespressoblackfalse
\DeclareOptionBeamer{myespressoblack}{\beamer@me@myespressoblacktrue}

\newif\ifbeamer@me@sidebar
\beamer@me@sidebarfalse
\def\myespresso@sidebarwidth{60pt}
\DeclareOptionBeamer{sidebarwidth}{\def\myespresso@sidebarwidth{#1}}
\DeclareOptionBeamer{sidebar}{\beamer@me@sidebartrue}

\newif\ifbeamer@me@toplogo
\beamer@me@toplogofalse
\DeclareOptionBeamer{toplogo}{\beamer@me@toplogotrue}

\newif\ifbeamer@me@leftframetitle
\beamer@me@leftframetitlefalse
\DeclareOptionBeamer{leftframetitle}{\beamer@me@leftframetitletrue}

\newif\ifbeamer@me@rule
\beamer@me@rulefalse
\DeclareOptionBeamer{rule}{\beamer@me@ruletrue}
\DeclareOptionBeamer{rulecolor}{\colorlet{MyEspresso@rule}{#1}}

\ProcessOptionsBeamer

% =================================================================
% Conditional packages
% =================================================================

\RequirePackage{fontawesome5}
\RequirePackage{iftex}

\ifbeamer@me@delaunay
  \ifLuaTeX
    \RequirePackage{luamesh}
  \else
    \PackageError{beamerthemeMyEspresso}%
      {The 'delaunay' option requires LuaLaTeX}%
      {Compile with lualatex instead of pdflatex or xelatex.}
  \fi
\fi

% Random seed for Delaunay mesh
\ExplSyntaxOn
\sys_gset_rand_seed:n { \time }
\ExplSyntaxOff

% =================================================================
% TOC depth counter for \sepframe
% =================================================================

\newcounter{myespressotoc}
\setcounter{myespressotoc}{1}
\newcounter{myespresso@oldtoc}

% =================================================================
% Metadata commands (global tl — used across group boundaries)
% =================================================================

\ExplSyntaxOn

\tl_new:N \g_myespresso_mail_tl
\tl_new:N \g_myespresso_webpage_tl
\tl_new:N \g_myespresso_collab_tl

\NewDocumentCommand { \mail } { m }
  { \tl_gset:Nn \g_myespresso_mail_tl { #1 } }

\NewDocumentCommand { \webpage } { m }
  { \tl_gset:Nn \g_myespresso_webpage_tl { #1 } }

\NewDocumentCommand { \collaboration } { m }
  { \tl_gset:Nn \g_myespresso_collab_tl { #1 } }

\NewDocumentCommand { \myespresso@printmail } { }
  {
    \tl_if_empty:NF \g_myespresso_mail_tl
      { \tl_use:N \g_myespresso_mail_tl }
  }

\NewDocumentCommand { \myespresso@printwebpage } { }
  {
    \tl_if_empty:NF \g_myespresso_webpage_tl
      { \tl_use:N \g_myespresso_webpage_tl }
  }

\ExplSyntaxOff

% =================================================================
% Load sub-themes
% =================================================================

\usecolortheme{MyEspresso}
\usefonttheme{MyEspresso}
\useinnertheme{MyEspresso}
\useoutertheme{MyEspresso}

% =================================================================
% Progress gauge
% =================================================================

\newlength{\gauge@progress}
\NewDocumentCommand{\myespresso@gauge}{o}{%
  \def\myespresso@gaugewidth{40pt}%
  \IfNoValueF{#1}{\def\myespresso@gaugewidth{#1}}%
  \setlength{\gauge@progress}{%
    (\myespresso@gaugewidth-2pt)*\insertframenumber/\insertmainframenumber}%
  \begin{tikzpicture}[x=0.7cm,y=0.7cm]%
    \draw[color=white]
      (0pt,-2pt) -- (\myespresso@gaugewidth,-2pt) --
      (\myespresso@gaugewidth,4pt) -- (0pt,4pt) -- cycle;%
    \fill[color=white]
      (1pt,-1pt) -- (\the\gauge@progress+1pt,-1pt) --
      (\the\gauge@progress+1pt,3pt) -- (1pt,3pt) -- cycle;%
  \end{tikzpicture}%
}

% =================================================================
% Delaunay mesh generation (LuaLaTeX only)
% =================================================================

\ExplSyntaxOn
\tl_new:N \l_delaunaypointlist_tl

\NewDocumentCommand { \myespresso@buildpoints } { }
  {
    \tl_clear:N \l_delaunaypointlist_tl
    \int_set:Nn \l_tmpa_int { 1 }
    \tl_put_right:Nn \l_delaunaypointlist_tl
      { (0,0);(16,0);(16,4.5);(0,4.5); }
    \int_do_while:nNnn { \l_tmpa_int } < { 40 }
      {
        \tl_put_right:Nn \l_delaunaypointlist_tl
          { (\fpeval{16*rand()},\fpeval{4.5*rand()}); }
        \int_incr:N \l_tmpa_int
      }
    \tl_put_right:Nn \l_delaunaypointlist_tl
      { (\fpeval{16*rand()},\fpeval{4.5*rand()}) }
  }

\NewExpandableDocumentCommand { \myespresso@buildmesh } { }
  {
    \node [anchor=north~west]
      at ([xshift=-50pt,yshift=30pt]current~page.north~west)
      {
        \resizebox{1.5\paperwidth}{0.8\paperheight}
          {
            \buildMeshBW
              [color=structure!15,colorBbox=structure!15,scale=2cm]
              { \l_delaunaypointlist_tl }
          }
      };
  }
\ExplSyntaxOff

% =================================================================
% \framesection — in-slide section heading
% =================================================================

\ExplSyntaxOn
\NewDocumentCommand { \framesection } { m }
  {
    \medskip
    \noindent
    {\large\bfseries\textcolor{structure}{#1}}
    \par\vspace*{-0.2cm}
    \hspace*{-\c_myespresso_margin}
    {\color{structure}\rule{0.4\paperwidth}{2pt}}
    \par\smallskip
  }
\ExplSyntaxOff

% =================================================================
% \sepframe — section separator with TOC
% =================================================================

\ExplSyntaxOn
\keys_define:nn { myespresso/sepframe }
  {
    title .tl_set:N = \l__myespresso_sepframe_title_tl ,
    image .tl_set:N = \l__myespresso_sepframe_image_tl ,
  }

\NewDocumentCommand { \sepframe } { o }
  {
    \IfNoValueF { #1 }
      { \keys_set:nn { myespresso/sepframe } { #1 } }
    \begingroup
    \setcounter{myespresso@oldtoc}{\value{tocdepth}}
    \setbeamercolor{section~in~toc}{fg=white}
    \tl_if_empty:NTF \l__myespresso_sepframe_title_tl
      { \def\myespresso@septitle{\secname} }
      { \def\myespresso@septitle{\l__myespresso_sepframe_title_tl} }
    \setbeamertemplate{background}{}
    \setbeamertemplate{navigation~symbols}{}
    \setbeamercolor{background~canvas}{bg=white}
    \begin{frame}[noframenumbering,plain]
      \begin{tikzpicture}[remember~picture,overlay]
        \ifbeamer@me@delaunay
          \ifLuaTeX
            \myespresso@buildpoints
            \myespresso@buildmesh
          \fi
        \fi
        \fill [structure]
          ([yshift=15pt]current~page.west)
          rectangle
          (current~page.south~east);
        \ifbeamer@me@rule
          \fill [MyEspresso@rule]
            ([yshift=15pt]current~page.west)
            rectangle
            ([yshift=10pt]current~page.east);
        \fi
        \node [anchor=east, text~width=0.7\paperwidth,
               font=\huge\bfseries, align=right, inner~sep=0pt]
          at ([yshift=-50pt,xshift=-25pt]current~page.north~east)
          (section)
          { \textcolor{structure}{\myespresso@septitle} };
        \node []
          at ([yshift=-40pt]current~page.center)
          (toc)
          {
            \color{white}
            \begin{minipage}{0.9\paperwidth}
              \begin{multicols}{2}
                \hypersetup{linkcolor=white}
                \setcounter{tocdepth}{\themyespressotoc}
                \tableofcontents
              \end{multicols}
            \end{minipage}
          };
        \tl_if_empty:NF \l__myespresso_sepframe_image_tl
          {
            \node [anchor=south~west]
              at ([yshift=20pt]current~page.west)
              (logo)
              {
                \parbox[t]{.19\paperwidth}
                  {
                    \raggedleft
                    \usebeamercolor[fg]{titlegraphic}
                    \l__myespresso_sepframe_image_tl
                  }
              };
          }
      \end{tikzpicture}
      \setcounter{tocdepth}{\value{myespresso@oldtoc}}
    \end{frame}
    \endgroup
  }
\ExplSyntaxOff

% =================================================================
% \thanksframe — closing slide
% =================================================================

\NewDocumentCommand{\thanksframe}{o m}{%
  \begingroup
  \setbeamertemplate{background}{}
  \setbeamertemplate{navigation symbols}{}
  \setbeamercolor{background canvas}{bg=white}
  \IfNoValueTF{#1}{%
    \def\myespresso@finalgraphic{\inserttitlegraphic}%
  }{%
    \def\myespresso@finalgraphic{#1}%
  }%
  \begin{frame}[noframenumbering,plain]
    \begin{tikzpicture}[remember picture,overlay]
      \ifbeamer@me@delaunay
        \ifLuaTeX
          \myespresso@buildpoints
          \myespresso@buildmesh
        \fi
      \fi
      \fill[structure]
        ([yshift=15pt]current page.west)
        rectangle
        (current page.south east);
      \ifbeamer@me@rule
        \fill[MyEspresso@rule]
          ([yshift=15pt]current page.west)
          rectangle
          ([yshift=10pt]current page.east);
      \fi
      % Anchor / position / width matched to the title-page node in
      % beamerinnerthemeMyEspresso.sty so the front and back covers
      % share the same visual layout. yshift=-15pt places the top of
      % the closing message 30pt below the split rule line (same
      % breathing room as the front title).
      \node[anchor=north east, inner sep=0pt]
        at ([yshift=-4pt,xshift=-20pt]current page.east)
        (section)
        {\usebeamerfont{title}%
         \parbox[t]{0.9\paperwidth}{\raggedleft
           \color{white}\vspace*{-\topskip}%
           #2}};
      \node[anchor=south west]
        at ([yshift=20pt]current page.west)
        (logo)
        {\parbox[t]{.19\paperwidth}{\raggedleft
          \usebeamercolor[fg]{titlegraphic}\myespresso@finalgraphic}};
    \end{tikzpicture}
  \end{frame}
  \endgroup
}

% =================================================================
% \boxalert — highlighted inline text
% =================================================================

\newenvironment{boxalertenv}{\begin{altenv}%
      {\usebeamertemplate{alerted text begin}%
       \usebeamercolor[fg]{alerted text}%
       \usebeamerfont{alerted text}\colorbox{bg}}
      {\usebeamertemplate{alerted text end}}{\color{.}}{}}{\end{altenv}}

\newcommand<>{\boxalert}[1]{{%
  \begin{boxalertenv}#2{#1}\end{boxalertenv}%
}}

% =================================================================
% Hyperlink colors
% =================================================================

\hypersetup{
    colorlinks=true,
    linkcolor=structure.fg!60,
    citecolor=alerted text.fg!60,
    urlcolor=structure.fg!60,
    anchorcolor=structure.fg!60,
    filecolor=structure.fg!60,
    linktoc=page,
}

\mode<all>
\endinput
