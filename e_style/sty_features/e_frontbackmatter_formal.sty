% =================================================================
% e_frontbackmatter_formal.sty
% Formal front and back matter for book-based document classes.
%
% AMS-compatible metadata API:
%   \author{Name}          -- one call per author (sequential)
%   \email{addr}            -- attaches to most recent \author
%   \address{affiliation}  -- attaches to most recent \author
%   \addauthor[email][addr]{Name}  -- one-call convenience
%   \title{...}            -- standard LaTeX
%   \subtitle{...}         -- extension: rendered below title
%   \institution{...}      -- extension: document-level institution
%   \location{...}         -- extension: city/venue for course notes
%   \date{...}             -- standard LaTeX
%   \dedicatory{...}       -- AMS-compatible dedication
%   \keywords{...}         -- AMS-compatible keyword list
%   \subjclass[year]{...}  -- AMS-compatible MSC classification
%   \setabstract[label]{body}            -- multilingual-capable (repeatable)
%   \setacknowledgements[label]{body}    -- multilingual-capable (repeatable)
%
% Output commands (called in document body):
%   \makefrontmatter       -- title page
%   \makededication        -- dedication page (if set)
%   \makeabstract          -- abstract page(s) (iterates all \setabstract calls)
%   \makeacknowledgements  -- acknowledgements page(s) (iterates)
%   \makebackmatter        -- back cover with copyright
%
% Customisation points (redefine in preamble):
%   \efmabstractlabel          -- "Abstract" (default)
%   \efmacknowledgementslabel  -- "Acknowledgements"
%   \efmsubjclassprefix        -- "Mathematics Subject Classification."
%   \efmkeywordsprefix         -- "Key words and phrases."
%   \efmfrontmatterheading{#1} -- heading style for abstract/ack pages
%                                 (default: centered bold \large + 1em vskip)
%
% Multilingual abstracts/acknowledgements:
%   Each \setabstract call pushes onto an internal sequence. Multiple
%   calls yield multiple pages (one per call) when \makeabstract fires.
%   The optional [label] overrides the heading text for that page:
%       \setabstract[Résumé]{Ce document presente...}
%       \setabstract[Abstract]{This document presents...}
%
% Hyperref integration:
%   If hyperref is loaded, pdftitle/pdfauthor/pdfkeywords are populated
%   automatically at \AtBeginDocument from the stored metadata.
% =================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{e_frontbackmatter_formal}%
  [2026/04/23 Formal front/back matter (AMS-compatible API)]


% =================================================================
% Customisation points (user-redefinable, no @ in names so that no
% \makeatletter wrapper is needed in preamble \renewcommand calls).
% =================================================================

\providecommand{\efmabstractlabel}{Abstract}
\providecommand{\efmacknowledgementslabel}{Acknowledgements}
\providecommand{\efmsubjclassprefix}{Mathematics~Subject~Classification.}
\providecommand{\efmkeywordsprefix}{Key~words~and~phrases.}

% Heading style for front-matter pages (abstract, acknowledgements).
% Default: centered bold \large with 1em vskip below. Redefine to
% \chapter*{#1} for book-chapter-style headings, or customise freely.
\providecommand{\efmfrontmatterheading}[1]{%
    \begin{center}\textbf{\large #1}\end{center}\vspace{1em}%
}


\ExplSyntaxOn

% =================================================================
% 1. Data storage
% =================================================================

% Three parallel sequences: one entry per \author call.
% \email and \address overwrite the slot for the current author.
\seq_new:N \g__efm_authors_seq
\seq_new:N \g__efm_emails_seq
\seq_new:N \g__efm_addresses_seq

% Index of the current (most recent) author
\int_new:N \g__efm_author_count_int

% Scalar metadata fields
\tl_new:N \g__efm_subtitle_tl
\tl_new:N \g__efm_institution_tl
\tl_new:N \g__efm_location_tl
\tl_new:N \g__efm_keywords_tl
\tl_new:N \g__efm_subjclass_tl
\tl_new:N \g__efm_subjclass_year_tl
\tl_new:N \g__efm_dedication_tl

% Sequences for abstract and acknowledgements (repeatable, multilingual)
\seq_new:N \g__efm_abstract_labels_seq
\seq_new:N \g__efm_abstract_bodies_seq
\seq_new:N \g__efm_acknowl_labels_seq
\seq_new:N \g__efm_acknowl_bodies_seq


% =================================================================
% 2. Author commands (AMS sequential pattern)
% =================================================================

% \author{Name} -- push a new author; reset email/address slots.
\RenewDocumentCommand { \author } { m }
  {
    \seq_gput_right:Nn \g__efm_authors_seq   { #1 }
    \seq_gput_right:Nn \g__efm_emails_seq    { }
    \seq_gput_right:Nn \g__efm_addresses_seq { }
    \int_gincr:N \g__efm_author_count_int
  }

% \email{addr} -- attach to the current author.
\NewDocumentCommand { \email } { m }
  {
    \int_compare:nNnT { \g__efm_author_count_int } > { 0 }
      {
        \seq_gset_item:Nnn \g__efm_emails_seq
          { \g__efm_author_count_int } { #1 }
      }
  }

% \address{affiliation} -- attach to the current author.
% Distinct from the document-level \institution.
\NewDocumentCommand { \address } { m }
  {
    \int_compare:nNnT { \g__efm_author_count_int } > { 0 }
      {
        \seq_gset_item:Nnn \g__efm_addresses_seq
          { \g__efm_author_count_int } { #1 }
      }
  }

% \addauthor[email][address]{Name} -- one-call convenience.
% Equivalent to \author{Name} + optional \email{...} + optional \address{...}.
\NewDocumentCommand { \addauthor } { O{} O{} m }
  {
    \author{#3}
    \tl_if_blank:nF { #1 } { \email{#1} }
    \tl_if_blank:nF { #2 } { \address{#2} }
  }


% =================================================================
% 3. Document-level metadata commands
% =================================================================

\NewDocumentCommand { \subtitle } { m }
  { \tl_gset:Nn \g__efm_subtitle_tl { #1 } }

\NewDocumentCommand { \institution } { m }
  { \tl_gset:Nn \g__efm_institution_tl { #1 } }

\NewDocumentCommand { \location } { m }
  { \tl_gset:Nn \g__efm_location_tl { #1 } }

\NewDocumentCommand { \keywords } { m }
  { \tl_gset:Nn \g__efm_keywords_tl { #1 } }

% \subjclass[2020]{35Q89, 49N80}
\NewDocumentCommand { \subjclass } { O{2020} m }
  {
    \tl_gset:Nn \g__efm_subjclass_year_tl { #1 }
    \tl_gset:Nn \g__efm_subjclass_tl { #2 }
  }

\NewDocumentCommand { \dedicatory } { +m }
  { \tl_gset:Nn \g__efm_dedication_tl { #1 } }

% \setabstract[label]{body} -- repeatable; each call pushes a new abstract.
% Default label is \efmabstractlabel (user-redefinable).
\NewDocumentCommand { \setabstract } { O{\efmabstractlabel} +m }
  {
    \seq_gput_right:Nn \g__efm_abstract_labels_seq { #1 }
    \seq_gput_right:Nn \g__efm_abstract_bodies_seq { #2 }
  }

% \setacknowledgements[label]{body} -- repeatable; each call pushes a new ack block.
\NewDocumentCommand { \setacknowledgements } { O{\efmacknowledgementslabel} +m }
  {
    \seq_gput_right:Nn \g__efm_acknowl_labels_seq { #1 }
    \seq_gput_right:Nn \g__efm_acknowl_bodies_seq { #2 }
  }


% =================================================================
% 4. Output: title page
% =================================================================

\NewDocumentCommand { \makefrontmatter } { }
  {
    \begin{titlepage}
      \thispagestyle{empty}
      \mbox{} \vfill
      \begin{center}
        \large

        % -- Institution (document-level) --
        \tl_if_blank:VF \g__efm_institution_tl
          {
            \begin{tabular}{c}
              \tl_use:N \g__efm_institution_tl
            \end{tabular}
            \par \vfill
          }

        % -- Title --
        { \LARGE \@title } \par

        % -- Subtitle --
        \tl_if_blank:VF \g__efm_subtitle_tl
          {
            \vspace{1em}
            \MakeUppercase { \normalsize \tl_use:N \g__efm_subtitle_tl }
          }

        \vfill

        % -- Authors --
        % Each author is printed with optional superscript (if email
        % exists) and optional address line below in smaller type.
        \normalsize
        \seq_map_indexed_inline:Nn \g__efm_authors_seq
          {
            ##2
            \tl_set:Nx \l_tmpa_tl
              { \seq_item:Nn \g__efm_emails_seq { ##1 } }
            \tl_if_blank:VF \l_tmpa_tl
              { \textsuperscript { ##1 } }
            \tl_set:Nx \l_tmpb_tl
              { \seq_item:Nn \g__efm_addresses_seq { ##1 } }
            \tl_if_blank:VF \l_tmpb_tl
              { \par {\small \l_tmpb_tl} }
            \par \vspace{0.5em}
          }

        \vfill

        % -- Location and date --
        \tl_if_blank:VF \g__efm_location_tl
          { \tl_use:N \g__efm_location_tl \par \vspace{0.5em} }
        \@date

      \end{center}
      \vfill

      % -- Footer: emails, classification, keywords --
      \par \noindent
      \begin{minipage}{\textwidth}

        % Email directory (only if at least one email is non-blank)
        \bool_set_false:N \l_tmpa_bool
        \seq_map_inline:Nn \g__efm_emails_seq
          { \tl_if_blank:nF { ##1 } { \bool_set_true:N \l_tmpa_bool } }
        \bool_if:NT \l_tmpa_bool
          {
            \rule{0.35\textwidth}{0.45pt} \par
            \seq_map_indexed_inline:Nn \g__efm_emails_seq
              {
                \tl_if_blank:nF { ##2 }
                  { \textsuperscript { ##1 } \texttt { ##2 } \par }
              }
          }

        % Subject classification
        \tl_if_blank:VF \g__efm_subjclass_tl
          {
            \vspace{0.5em}
            \textit
              {
                \tl_use:N \g__efm_subjclass_year_tl
                \ \efmsubjclassprefix
              } ~
            \tl_use:N \g__efm_subjclass_tl \par
          }

        % Keywords
        \tl_if_blank:VF \g__efm_keywords_tl
          {
            \vspace{0.3em}
            \textit { \efmkeywordsprefix } ~
            \tl_use:N \g__efm_keywords_tl \par
          }

      \end{minipage}
    \end{titlepage}
    \cleardoublepage
  }


% =================================================================
% 5. Output: optional front matter pages
% =================================================================

\NewDocumentCommand { \makededication } { }
  {
    \tl_if_blank:VF \g__efm_dedication_tl
      {
        \clearpage \thispagestyle{empty}
        \vspace*{3cm}
        \tl_use:N \g__efm_dedication_tl
        \cleardoublepage
      }
  }

% Iterate over all stored abstracts, rendering each on its own page.
% Each iteration starts with \clearpage (not \cleardoublepage) so
% consecutive multilingual abstracts pack onto successive pages
% without forced blank versos in twoside layout.
\NewDocumentCommand { \makeabstract } { }
  {
    \seq_map_indexed_inline:Nn \g__efm_abstract_labels_seq
      {
        \clearpage
        \thispagestyle{empty}
        \efmfrontmatterheading{##2}
        \seq_item:Nn \g__efm_abstract_bodies_seq { ##1 }
      }
  }

\NewDocumentCommand { \makeacknowledgements } { }
  {
    \seq_map_indexed_inline:Nn \g__efm_acknowl_labels_seq
      {
        \clearpage
        \thispagestyle{empty}
        \efmfrontmatterheading{##2}
        \seq_item:Nn \g__efm_acknowl_bodies_seq { ##1 }
      }
  }


% =================================================================
% 6. Output: back cover
% =================================================================

\NewDocumentCommand { \makebackmatter } { }
  {
    \thispagestyle{empty}
    \vfill
    \noindent
    \seq_use:Nn \g__efm_authors_seq { ,~ }
    :~ \textit { \@title, } ~ \textcopyright\ \@date
    \cleardoublepage
  }

\ExplSyntaxOff


% =================================================================
% 7. Hyperref integration (automatic PDF metadata sync)
% =================================================================
% At \begin{document}, if hyperref is loaded, populate pdftitle,
% pdfauthor, pdfkeywords from the stored metadata. One source of
% truth; no manual \hypersetup duplication needed.
%
% Implementation detail: the whole block (definition AND hook
% registration) lives inside \ExplSyntaxOn so that `:` and `_` in
% \__efm_sync_pdfmeta: are read as letters. If the \AtBeginDocument
% body were tokenised outside \ExplSyntaxOn, the stored tokens would
% contain a cat-8 subscript `_` that triggers math-mode errors when
% the hook fires.
%
% We pre-build the keyval string via \tl_set:Nx (fully expanding L3
% accessors) and feed the result to \hypersetup via \exp_args:NV.
% Passing L3 accessors directly inside \hypersetup{...} would fail
% because \hypersetup tokenises before expansion.
\ExplSyntaxOn
\cs_new_protected:Npn \__efm_sync_pdfmeta:
  {
    \tl_set:Nx \l_tmpa_tl
      {
        pdftitle    = { \@title } ,
        pdfauthor   = { \seq_use:Nn \g__efm_authors_seq { ,~ } } ,
        pdfkeywords = { \tl_use:N \g__efm_keywords_tl }
      }
    \exp_args:NV \hypersetup \l_tmpa_tl
  }

\AtBeginDocument
  {
    \@ifpackageloaded { hyperref }
      { \__efm_sync_pdfmeta: }
      { }
  }
\ExplSyntaxOff

\endinput
