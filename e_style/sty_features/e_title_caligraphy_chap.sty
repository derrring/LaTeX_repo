% =================================================================
% e_title_caligraphy_chap.sty
% Chapter title style with large calligraphic chapter numbers
% (Alegreya font, oldstyle figures).
% =================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{e_title_caligraphy_chap}%
  [2026/04/12 v1.1 Calligraphic chapter titles]

% Shared \part formatting (Roman numerals, centered, colored)
\RequirePackage{e_title_part}

% =================================================================
% Calligraphic chapter number font
% =================================================================

\newfontfamily\alegchapter{Alegreya}[
    Numbers=OldStyle,
    UprightFont=*-Regular,
    BoldFont=*-Bold,
    ItalicFont=*-Italic,
    BoldItalicFont=*-BoldItalic,
]

\newcommand{\chapterNumber}{%
    \alegchapter\mdseries\upshape\fontsize{108pt}{120pt}\selectfont
}

% =================================================================
% Chapter title format
% =================================================================

\titleformat{\chapter}[display]
    {\normalfont}
    {\vspace*{-3\baselineskip}%
     \makebox[\linewidth][r]{\color{titlecolorchapter}\chapterNumber\thechapter}}%
    {15pt}
    {\raggedright\bfseries\large\MakeUppercase}
    [\normalsize\vspace*{.8\baselineskip}\titlerule]

\endinput
