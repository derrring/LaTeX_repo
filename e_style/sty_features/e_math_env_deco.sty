\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{e_math_env_deco}[E Math Environment Decoration]
%----------  wrap/decorate !EXISTED! theorem-like environments ----------------
%------------------------realized by tcolorbox-------------------------
%
% proof and remark are intentionally left UNDECORATED:
%   - Semantically discursive (not statements to reference)
%   - Readers identify proofs by "Proof." heading and QED symbol
%   - Avoids tcolorbox minipage boxing, so \footnote works natively
%   - Consistent with standard mathematical typesetting (Rudin, Serre, Bourbaki)

\tcolorboxenvironment{definition}{
    enhanced,breakable,
    frame hidden,
    colback=mydefinitioncolor!5!white,
    borderline west={1mm}{0pt}{mydefinitioncolor!90!black},
    before skip=.5em,after skip=\parskip,width=\linewidth,
}
\tcolorboxenvironment{theorem}{
    enhanced,breakable,
    frame hidden,
    colback=mytheoremcolor!5!white,
    borderline west={1mm}{0pt}{mytheoremcolor!90!black},
    before skip=.5em,after skip=\parskip,
}

\tcolorboxenvironment{proposition}{
    enhanced,breakable,
    frame hidden,
    colback=mypropositioncolor!5!white,
    borderline west={1mm}{0pt}{mypropositioncolor!50!black},
    before skip=.5em,after skip=\parskip,
}

\tcolorboxenvironment{corollary}{
    enhanced,breakable,
    frame hidden,
    colback=mycorollarycolor!5!white,
    borderline west={1mm}{0pt}{mycorollarycolor!50!black},
    before skip=.5em,after skip=\parskip,
}
\tcolorboxenvironment{lemma}{
    enhanced,breakable,
    frame hidden,
    colback=mylemmacolor!5!white,
    borderline west={1mm}{0pt}{mylemmacolor!50!black},
    before skip=.5em,after skip=\parskip,
}
\endinput
