% =================================================================
% e_frontbackmatter_simple.sty
% Minimal frontmatter that defers to the base class \maketitle.
%
% Stubs all metadata commands from e_frontbackmatter_formal so that
% documents compile without errors when switching between styles.
% =================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{e_frontbackmatter_simple}%
  [2026/04/11 Simple frontmatter (base-class defaults)]

% Stub formal-only metadata commands (accept argument, do nothing).
\newcommand{\subtitle}[1]{}
\newcommand{\institution}[1]{}
\newcommand{\location}[1]{}
\newcommand{\email}[1]{}
\newcommand{\address}[1]{}
\newcommand{\dedicatory}[1]{}
\newcommand{\keywords}[1]{}
\newcommand{\subjclass}[2][]{}
\newcommand{\setabstract}[1]{}
\newcommand{\setacknowledgements}[1]{}

% We intentionally do NOT redefine \maketitle here.
% The base class (book or article) provides its own \maketitle,
% which is the desired behavior for simple frontmatter.

\endinput
